{
  "name": "source-mysql-transactions",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSourceConnector",
    "tasks.max": "1",
    "connection.url": "jdbc:mysql://mysql:3306/db?user=user&password=password&useSSL=false",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "poll.interval.ms": 5000,
    "table.whitelist": "sales_transactions",
    "mode": "timestamp",
    "timestamp.column.name": "timestamp",

    "transforms": "route,ToKey,KeyString",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "sales_transactions",
    "transforms.route.replacement": "sales-transactions",

    "transforms.ToKey.type": "org.apache.kafka.connect.transforms.ValueToKey",
    "transforms.ToKey.fields": "transaction_id",

    "transforms.KeyString.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
    "transforms.KeyString.field": "transaction_id"
  }
}